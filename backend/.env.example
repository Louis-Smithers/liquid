# Smithers Backend — Environment Variables Reference
# ASP.NET Core reads config from appsettings.json, appsettings.{Environment}.json,
# and environment variables (using __ as section separator).
#
# Copy to .env and source it, OR use dotnet user-secrets for local dev:
#   dotnet user-secrets init
#   dotnet user-secrets set "ConnectionStrings:DefaultConnection" "..."
#
# Production: inject these as environment variables in your host / container.

# ── Database ────────────────────────────────────────────────────────────────
# Session pooler (IPv4, port 5432) — get from Supabase Dashboard → Connect → Session Pooler
# Username format: postgres.<project-ref>   Host format: aws-1-<region>.pooler.supabase.com
ConnectionStrings__DefaultConnection=Host=aws-1-<region>.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.<project-ref>;Password=your-db-password;SSL Mode=Require;Trust Server Certificate=true

# ── Supabase (JWT validated via OIDC discovery — no static secret needed)
Supabase__Url=https://your-project-ref.supabase.co

# ── CORS (comma-separated allowed origins for production)
Cors__AllowedOrigins=https://your-frontend.vercel.app

# ── Google Cloud Storage ──────────────────────────────────────────────────────
Google__ServiceAccountJson=<base64-encoded service account JSON key file>
Google__GcsBucketName=<your-bucket-name>

# ── Health monitoring (Discord alerts) ────────────────────────────────────────
# Discord channel → Edit Channel → Integrations → Webhooks → New Webhook → Copy URL.
# Leave blank to disable alerting (the /health endpoint still works).
Discord__WebhookUrl=https://discord.com/api/webhooks/<id>/<token>
# ── User feedback / bug reports (Discord) ─────────────────────────────────────
# Separate webhook so feedback lands in its own channel. Falls back to
# Discord__WebhookUrl if left blank. Leave both blank to silently drop feedback.
Discord__FeedbackWebhookUrl=https://discord.com/api/webhooks/<id>/<token>
# How often the background monitor polls the checks (seconds, min 10). Default 60.
HealthMonitor__IntervalSeconds=60
# OCR/intake degradation thresholds.
HealthMonitor__OcrQueueBacklogThreshold=25
HealthMonitor__OcrStuckBatchMinutes=30
